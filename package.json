{
  "name": "playwright-2a-advanced-ui-components",
  "version": "1.0.0",
  "description": "Playwright test suite for UI Testing Playground, exercising advanced UI component interactions with TypeScript and the Page Object Model.",
  "private": true,
  "author": "Paul Yardley",
  "license": "MIT",
  "keywords": [
    "playwright",
    "typescript",
    "e2e-testing",
    "page-object-model",
    "test-automation",
    "ui-testing-playground"
  ],
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "cross-env TEST_SUITE=smoke playwright test --grep @smoke",
    "test:e2e": "cross-env TEST_SUITE=e2e playwright test --grep @e2e",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-playwright": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
